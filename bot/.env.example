NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
BOT_DISPLAY_NAME=SaathiAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional. Set this when running in WSL/Linux if Puppeteer cannot find Chrome.
# Examples:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=

# Optional Sarvam batch STT. If omitted, voice notes are acknowledged and
# the learner is asked to send text.
SARVAM_API_KEY=
SARVAM_MODEL=saaras:v3
SARVAM_LANGUAGE_CODE=unknown
SARVAM_SAMPLE_RATE=16000
SARVAM_JOB_TIMEOUT_MS=120000
SARVAM_WITH_DIARIZATION=false
SARVAM_NUM_SPEAKERS=1
# WhatsApp voice notes are converted to 16k WAV before upload to Sarvam.
SARVAM_AUDIO_ENCODING=audio/wav

# Local JSON persistence paths.
DATA_DIR=./data/runtime
JOB_DATA_PATH=./data/jobs.json

# Backend-owned product data is always written to Supabase. Local JSON is only
# used for bot-private runtime state such as active WhatsApp sessions.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
