NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
BOT_DISPLAY_NAME=SaathiAI
LOG_LEVEL=info

# ── Database (direct Postgres connection) ─────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Groq AI (primary LLM provider) ────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=30000

# ── Gemini AI (fallback LLM provider) ────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ── Sarvam AI (optional — voice note transcription) ───────────────────────────
# Get from: https://dashboard.sarvam.ai
# If omitted, voice notes are skipped with a text prompt.
SARVAM_API_KEY=
SARVAM_MODEL=saaras:v3
SARVAM_LANGUAGE_CODE=unknown
SARVAM_SAMPLE_RATE=16000
SARVAM_JOB_TIMEOUT_MS=120000
SARVAM_WITH_DIARIZATION=false
SARVAM_NUM_SPEAKERS=1
SARVAM_AUDIO_ENCODING=audio/wav

# ── Local persistence ─────────────────────────────────────────────────────────
DATA_DIR=./data/runtime
JOB_DATA_PATH=./data/jobs.json

# ── Backend / CORS ────────────────────────────────────────────────────────────
BACKEND_PORT=4000
CORS_ORIGINS=http://localhost:3001

# ── Puppeteer (optional — set if WhatsApp Web fails to launch on Linux) ───────
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
PUPPETEER_EXECUTABLE_PATH=
