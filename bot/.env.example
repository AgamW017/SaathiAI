NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
BOT_DISPLAY_NAME=SaathiAI

# Optional. Set this when running in WSL/Linux if Puppeteer cannot find Chrome.
# Examples:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=

# Optional external AI endpoint. If omitted, deterministic local extractors are used.
SAATHI_AI_API_URL=
SAATHI_AI_API_KEY=

# Optional Sarvam streaming STT. If omitted, voice notes are acknowledged and
# the learner is asked to send text.
SARVAM_API_KEY=
SARVAM_MODEL=saaras:v3
SARVAM_LANGUAGE_CODE=hi-IN
SARVAM_SAMPLE_RATE=16000
SARVAM_STREAM_TIMEOUT_MS=12000
# WhatsApp voice notes are converted to 16k WAV before streaming to Sarvam.
SARVAM_AUDIO_ENCODING=audio/wav

# Local JSON persistence paths.
DATA_DIR=./data/runtime
JOB_DATA_PATH=./data/jobs.json
