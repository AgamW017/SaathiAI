/**
 * SaathiAI Backend — Example environment variables.
 * Copy this to .env.local and fill in the values.
 *
 * DO NOT commit .env.local to version control.
 */

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://khuxbwwjyqmjwscmnghu.supabase.co

# Service role key (bypasses RLS — NEVER expose to frontend)
# Settings → API → service_role key
SUPABASE_SECRET_KEY=<your-service-role-key>

# Anon/public key (used only for OAuth redirect flows)
SUPABASE_ANON_KEY=<your-anon-key>

# Direct Postgres connection (for db:init migrations)
DATABASE_URL=postgresql://postgres:<password>@db.khuxbwwjyqmjwscmnghu.supabase.co:5432/postgres

# URL where the bot's admin HTTP server is running (used by /admin/bot-status proxy)
BOT_INTERNAL_URL=http://localhost:3001

# ─── Groq LLM (primary provider) ───────────────────────────────────────────────
# API key for Groq (primary LLM — faster and cheaper, used first for all LLM tasks)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key>

# ─── Gemini LLM (fallback provider) ────────────────────────────────────────────
# API key for Google Gemini (fallback — used when Groq is unavailable or fails)
GEMINI_API_KEY=<your-gemini-api-key>

# ─── AI Server ─────────────────────────────────────────────────────────────────
# URL of the Python aiserver (document parsing + risk prediction).
# Default: http://localhost:5000  (same port as the docling server)
AISERVER_URL=http://localhost:5000

# ─── Sandbox.co.in — Aadhaar KYC ───────────────────────────────────────────────
# Credentials from https://sandbox.co.in — used for Aadhaar OTP-based KYC.
# NEVER expose these to the frontend or bot. The backend proxies all Sandbox calls.
SANDBOX_API_KEY=<your-sandbox-api-key>
SANDBOX_API_SECRET=<your-sandbox-api-secret>

# Base URL for Sandbox API.
# Use the test URL (default) during development; switch to production for live.
# Test: https://test-api.sandbox.co.in
# Prod: https://api.sandbox.co.in
SANDBOX_BASE_URL=https://test-api.sandbox.co.in

# ─── Bot internal auth ──────────────────────────────────────────────────────────
# Shared secret between the bot and this backend for /api/internal/* routes.
# Change this in production to a strong random string (same value in bot BOT_INTERNAL_SECRET).
BOT_INTERNAL_SECRET=dev-bot-secret
