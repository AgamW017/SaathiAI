/**
 * SaathiAI Backend — Example environment variables.
 * Copy this to .env.local and fill in the values.
 *
 * DO NOT commit .env.local to version control.
 */

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://khuxbwwjyqmjwscmnghu.supabase.co

# Service role key (bypasses RLS — NEVER expose to frontend)
# Settings → API → service_role key
SUPABASE_SERVICE_KEY=<your-service-role-key>

# Anon/public key (used only for OAuth redirect flows)
SUPABASE_ANON_KEY=<your-anon-key>

# Direct Postgres connection (for db:init migrations)
DATABASE_URL=postgresql://postgres:<password>@db.khuxbwwjyqmjwscmnghu.supabase.co:5432/postgres

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<your-256-bit-random-hex-secret>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Bot ↔ Backend internal secret ────────────────────────────────────────────
# Shared secret for bot to call /internal/bot-events
BOT_INTERNAL_SECRET=<random-shared-secret>

# URL where the bot's admin HTTP server is running (used by /admin/bot-status proxy)
BOT_INTERNAL_URL=http://localhost:3001
